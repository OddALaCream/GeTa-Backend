# =============================================================
# Base de datos — Supabase
# Project Settings → Database → Connection string (URI)
# o completa los campos por separado:
# =============================================================
DB_HOST=db.<TU-PROJECT-REF>.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=<TU-PASSWORD-DE-SUPABASE>
DB_NAME=postgres

# DB_SYNC=true  → TypeORM crea/modifica tablas automáticamente
# DB_SYNC=false → usas el schema manual (database/schema.sql)
# Con Supabase siempre usa false y ejecuta schema.sql manualmente
DB_SYNC=false

# =============================================================
# JWT — cambia el secret en producción
# =============================================================
JWT_SECRET=pon-aqui-un-string-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# =============================================================
# Aplicación
# =============================================================
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
