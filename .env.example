# =============================================================
# Base de datos - Supabase
# Recomendado para desarrollo local/Windows/IPv4:
# usa Session pooler desde Connect -> Session pooler.
# Puedes pegar la URI completa o completar los campos por separado.
# =============================================================
# DATABASE_URL=postgresql://postgres.<TU-PROJECT-REF>:<TU-PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres
DB_HOST=aws-0-<REGION>.pooler.supabase.com
DB_PORT=5432
DB_USERNAME=postgres.<TU-PROJECT-REF>
DB_PASSWORD=<TU-PASSWORD-DE-SUPABASE>
DB_NAME=postgres
DB_SSL=true

# DB_SYNC=true  -> TypeORM crea/modifica tablas automaticamente
# DB_SYNC=false -> usas el schema manual (database/schema.sql)
# Con Supabase siempre usa false y ejecuta schema.sql manualmente
DB_SYNC=false

# =============================================================
# JWT - cambia el secret en produccion
# =============================================================
JWT_SECRET=pon-aqui-un-string-largo-y-aleatorio
JWT_EXPIRES_IN=7d

# =============================================================
# Aplicacion
# =============================================================
PORT=3000
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
